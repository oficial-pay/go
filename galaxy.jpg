import { createFileRoute } from "@tanstack/react-router";
import { useState } from "react";
import { motion } from "framer-motion";
import { TikTokLogo } from "@/components/TikTokLogo";
import { QuizCard, QuizShell } from "@/components/QuizCard";
import { Result } from "@/components/Result";
import { Products } from "@/components/Products";
import { QUESTIONS } from "@/lib/quiz-data";

export const Route = createFileRoute("/")({
  head: () => ({
    meta: [
      { title: "Quiz TikTok — Descubra seu nível e ganhe prêmios" },
      {
        name: "description",
        content: "Descubra seu nível de TikToker e ganhe prêmios exclusivos!",
      },
      { property: "og:title", content: "Quiz TikTok — Descubra seu nível" },
      {
        property: "og:description",
        content: "Descubra seu nível de TikToker e ganhe prêmios exclusivos!",
      },
    ],
  }),
  component: Index,
});

type Stage = "landing" | "quiz" | "result" | "products";

function Index() {
  const [stage, setStage] = useState<Stage>("landing");
  const [step, setStep] = useState(0);
  const [score, setScore] = useState(0);
  const [streak, setStreak] = useState(0);
  const [bestStreak, setBestStreak] = useState(0);
  const [playing] = useState(2847 + Math.floor(Math.random() * 50));

  function handleAnswer(points: number) {
    const newScore = score + points;
    setScore(newScore);
    const newStreak = points >= 4 ? streak + 1 : 0;
    setStreak(newStreak);
    if (newStreak > bestStreak) setBestStreak(newStreak);

    if (step + 1 >= QUESTIONS.length) {
      setStage("result");
    } else {
      setStep(step + 1);
    }
  }

  return (
    <main className="min-h-screen relative overflow-hidden flex flex-col items-center justify-start py-8 px-4">
      <Background />

      {stage === "landing" && (
        <Landing playing={playing} onStart={() => setStage("quiz")} />
      )}

      {stage === "quiz" && (
        <QuizShell>
          <QuizCard
            key={QUESTIONS[step].id}
            question={QUESTIONS[step]}
            index={step}
            total={QUESTIONS.length}
            onAnswer={handleAnswer}
          />
        </QuizShell>
      )}

      {stage === "result" && (
        <Result score={score} streak={bestStreak || 1} onRedeem={() => setStage("products")} />
      )}

      {stage === "products" && <Products />}
    </main>
  );
}

function Background() {
  return (
    <>
      <div
        className="fixed inset-0 -z-10"
        style={{
          background:
            "radial-gradient(ellipse at top, oklch(0.65 0.27 0 / 0.15), transparent 60%), radial-gradient(ellipse at bottom, oklch(0.83 0.16 200 / 0.12), transparent 60%), #080808",
        }}
      />
      <div className="fixed inset-0 -z-10 opacity-40">
        {[...Array(6)].map((_, i) => (
          <div
            key={i}
            className="absolute rounded-full bg-tiktok-cyan/30 blur-3xl animate-float"
            style={{
              width: `${60 + i * 20}px`,
              height: `${60 + i * 20}px`,
              top: `${10 + i * 15}%`,
              left: `${(i * 17) % 90}%`,
              animationDelay: `${i * 0.7}s`,
              animationDuration: `${6 + i}s`,
            }}
          />
        ))}
      </div>
    </>
  );
}

function Landing({ playing, onStart }: { playing: number; onStart: () => void }) {
  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      animate={{ opacity: 1, y: 0 }}
      className="w-full max-w-md mx-auto flex flex-col items-center"
    >
      <div className="mb-6 mt-4">
        <TikTokLogo size={140} />
      </div>

      <div className="rounded-3xl bg-card border border-border p-6 w-full text-center shadow-glow-magenta">
        <div className="inline-flex items-center gap-2 text-xs text-tiktok-success font-bold mb-4">
          <span className="w-2 h-2 rounded-full bg-tiktok-success animate-pulse" />
          {playing.toLocaleString("pt-BR")} jogando agora
        </div>

        <h1 className="text-3xl sm:text-4xl font-black leading-tight mb-3">
          <span className="text-gradient-tiktok">Você é viciado no TikTok?</span>{" "}
          <span>🎵</span>
        </h1>
        <p className="text-sm text-muted-foreground mb-5">
          Descubra seu nível de tiktoker e{" "}
          <span className="text-tiktok-pink font-bold">ganhe prêmios exclusivos!</span>
        </p>

        <div className="flex justify-center gap-2 mb-5 flex-wrap">
          <Pill icon="🔥" text="8 Perguntas" color="text-tiktok-orange border-tiktok-orange/40" />
          <Pill icon="🎁" text="Produtos Grátis" color="text-tiktok-pink border-tiktok-pink/40" />
        </div>

        <div className="rounded-2xl border-2 border-tiktok-gold/40 bg-tiktok-gold/5 p-3 mb-5 flex items-center gap-3">
          <div className="w-12 h-12 rounded-full bg-gradient-gold flex items-center justify-center text-2xl">
            🏆
          </div>
          <div className="flex-1 text-left">
            <p className="font-bold text-sm">Recompensa Garantida</p>
            <p className="text-[11px] text-muted-foreground">
              Complete o quiz e ganhe produtos incríveis
            </p>
          </div>
          <div className="px-2 py-1 rounded-full bg-tiktok-gold/20 text-tiktok-gold text-[10px] font-bold whitespace-nowrap">
            ⭐ Nível 1
          </div>
        </div>

        <p className="text-xs text-muted-foreground mb-4">
          ⏱️ Tempo estimado: 2 minutos
        </p>

        <button
          onClick={onStart}
          className="w-full py-4 rounded-2xl bg-gradient-cta text-white font-black text-lg shadow-cta animate-pulse-glow active:scale-[0.98] transition-transform"
        >
          🎮 COMEÇAR AGORA!
        </button>

        <div className="flex items-center justify-center gap-3 mt-5 text-xs text-muted-foreground">
          <span className="flex items-center gap-1">
            <span className="text-tiktok-gold">★★★★★</span>
            <span className="font-bold">4.9</span>
          </span>
          <span>•</span>
          <span>+50.000 jogadores</span>
          <span>•</span>
          <span>🇧🇷 Brasil</span>
        </div>
      </div>
    </motion.div>
  );
}

function Pill({ icon, text, color }: { icon: string; text: string; color: string }) {
  return (
    <div className={`px-4 py-1.5 rounded-full border-2 bg-secondary/40 text-xs font-bold flex items-center gap-1.5 ${color}`}>
      <span>{icon}</span> {text}
    </div>
  );
}
